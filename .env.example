# AI Provider API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Selectable models (chat + Agent) live in models.json — copy models.example.json
# to models.json and give each model its own id/base_url/api_key. The GATEWAY_*
# vars below are only a single-provider fallback used when models.json is absent.

# Optional: Custom Gateway (fallback when models.json is absent)
GATEWAY_URL=
GATEWAY_API_KEY=
GATEWAY_MODELS=

# Agent provider model defaults (OpenAI-compatible endpoint)
AGENT_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
DEFAULT_MODEL=mimo-v2.5-pro

# Agent mode runs on opencode (https://github.com/anomalyco/opencode).
# Start it locally first: bash scripts/opencode.sh
# OPENCODE_ENABLED=false falls back to the legacy in-process loop.
# OPENCODE_BASE_URL is the backend -> opencode server URL.
# OPENCODE_PROVIDER_BASE_URL optionally overrides the model gateway URL used by opencode.
# When the backend runs in Docker, use host.docker.internal to reach opencode
# on the host, and set OPENCODE_HOST_ROOT to the host-side absolute path of
# generated/agent_sessions so opencode can resolve cadquery.py files.
OPENCODE_ENABLED=true
OPENCODE_BASE_URL=http://host.docker.internal:4096
OPENCODE_PROVIDER_ID=cadgw
OPENCODE_PROVIDER_BASE_URL=
OPENCODE_HOST_ROOT=/absolute/path/to/CAD-studio/packages/backend/generated/agent_sessions

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./cad_studio.db

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# =============================================================
# RAG 知识库（可选）
# 用于机械设计 PDF 的向量检索。需要一个 OpenAI 兼容的 embedding 端点，
# 例如 OpenAI 官方或 qingyuntop。DeepSeek 不提供 embedding。
# 留空时后端会退化到本地 hash embedding（可跑但语义质量差）。
# =============================================================
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
